# Maintainer: Franz Jeger <franz@jeger.dev>
pkgname=supermanager-git
pkgver=0.1.0
pkgrel=1
pkgdesc="Unified SSH key + VPN connection manager (GUI + daemon)"
arch=('x86_64')
url="https://github.com/franzjeger/SuperManager"
license=('MIT')
depends=(
    'gtk4'
    'libadwaita'
    'sshpass'
    'wireguard-tools'
    'strongswan'
)
makedepends=(
    'rust'
    'cargo'
    'pkg-config'
    'git'
)
provides=('supermanager')
conflicts=('supermanager')
source=("${pkgname}::git+ssh://git@github.com/franzjeger/SuperManager.git")
sha256sums=('SKIP')

pkgver() {
    cd "$pkgname"
    if git describe --long --tags 2>/dev/null; then
        git describe --long --tags | sed 's/^v//;s/-/.r/;s/-/./g'
    else
        printf "0.1.0.r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
    fi
}

build() {
    cd "$pkgname"
    export CARGO_TARGET_DIR=target
    cargo build --release
}

package() {
    cd "$pkgname"

    # Binaries
    install -Dm755 target/release/supermgrd     "$pkgdir/usr/bin/supermgrd"
    install -Dm755 target/release/supermgr       "$pkgdir/usr/bin/supermgr"
    install -Dm755 target/release/supermgr-mcp   "$pkgdir/usr/bin/supermgr-mcp"

    # Systemd service
    install -Dm644 contrib/systemd/supermgrd.service \
        "$pkgdir/usr/lib/systemd/system/supermgrd.service"

    # D-Bus policy
    install -Dm644 contrib/dbus/org.supermgr.Daemon.conf \
        "$pkgdir/usr/share/dbus-1/system.d/org.supermgr.Daemon.conf"

    # Desktop entry
    install -Dm644 contrib/desktop/org.supermgr.SuperManager.desktop \
        "$pkgdir/usr/share/applications/org.supermgr.SuperManager.desktop"

    # Application icon (scalable SVG)
    install -Dm644 contrib/icons/org.supermgr.SuperManager.svg \
        "$pkgdir/usr/share/icons/hicolor/scalable/apps/org.supermgr.SuperManager.svg"

    # Config directory
    install -dm750 "$pkgdir/etc/supermgrd"

    # License
    if [ -f LICENSE ]; then
        install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
    fi
}

# macOS / Xcode
# The .xcodeproj is generated by `xcodegen generate` from
# SuperManagerMac/project.yml — don't commit it. project.yml IS the source of
# truth for the project structure; regenerate locally before building.
SuperManagerMac/SuperManager.xcodeproj/
SuperManagerMac/.build/
SuperManagerMac/build/
# Xcode user-specific cruft
SuperManagerMac/**/xcuserdata/
SuperManagerMac/**/*.xcuserstate
.DS_Store

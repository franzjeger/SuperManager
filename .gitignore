# Rust
/target/

# Python
__pycache__/
*.pyc

# Claude Code
.claude/

# Secrets / private material — defensive
*.enc
*.pem
*.key
secrets.json
settings.local.json
/migrate_from_old.py

# macOS / Xcode
# The .xcodeproj is generated by `xcodegen generate` from
# SuperManagerMac/project.yml — don't commit it. project.yml IS the source of
# truth for the project structure; regenerate locally before building.
SuperManagerMac/SuperManager.xcodeproj/
SuperManagerMac/.build/
SuperManagerMac/build/
# Xcode user-specific cruft
SuperManagerMac/**/xcuserdata/
SuperManagerMac/**/*.xcuserstate
.DS_Store
dist/

# Bundled third-party binaries dropped here by the installer build step.
# See vendor/README.md for the expected filenames and where to download
# them from. Tracked README + manifest.toml (the version + hash pin
# for the upstream installers) are in git; the binaries themselves are
# fetched fresh on every build by scripts/windows/Get-VendorFiles.ps1.
/vendor/*
!/vendor/README.md
!/vendor/manifest.toml

# WiX build outputs
/installer/wix/obj/
/installer/wix/SuperManager.msi
/installer/wix/SuperManager-Setup.exe
/installer/wix/*.wixpdb
# Auto-generated by scripts/windows/Stage-Openfortivpn.ps1
/installer/wix/openfortivpn-files.wxi

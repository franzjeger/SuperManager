<?xml version="1.0" encoding="UTF-8"?>
<!--
  SuperManager Windows MSI installer (WiX v4/v5 schema).

  Layout under %ProgramFiles%\SuperManager\:
    bin\supermgrd-win.exe   - privileged daemon (registered as `SuperManager`
                              Windows Service, autostart, LocalSystem)
    bin\supermgr-win.exe    - interactive-user GUI (Start Menu shortcut)
    bin\supermgr-mcp.exe    - MCP server stdio binary
    bin\openfortivpn.exe    - FortiClient SSL VPN binary (optional; only when
                              vendor\openfortivpn.exe is present at build time)
    scripts\install-service.ps1
    scripts\uninstall-service.ps1
    scripts\smoke-test.ps1
    docs\WINDOWS.md
    docs\README.md

  State (created by the daemon on first run, NOT by the installer):
    %ProgramData%\SuperManager\profiles\
    %ProgramData%\SuperManager\hosts\
    %ProgramData%\SuperManager\keys\
    %ProgramData%\SuperManager\backups\
    %ProgramData%\SuperManager\runtime\
    %ProgramData%\SuperManager\logs\
    %ProgramData%\SuperManager\known_hosts.json

  Upgrades:
    UpgradeCode is stable; ProductCode autogenerated. MajorUpgrade
    schedules the old version's uninstall in the same transaction as
    the new install. The service is stopped + reinstalled cleanly via
    ServiceControl + ServiceInstall.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
  <Package Name="SuperManager"
           Language="1033"
           Version="!(bind.FileVersion.supermgrd_win.exe)"
           Manufacturer="Sybr"
           UpgradeCode="9D7C2F4A-1A28-4F1D-90C0-7F1B2C9C5012"
           Compressed="yes"
           Scope="perMachine"
           InstallerVersion="500">

    <SummaryInformation Description="SuperManager - SSH, host, and VPN management for Windows" />

    <MediaTemplate EmbedCab="yes" />

    <MajorUpgrade DowngradeErrorMessage="A newer version of SuperManager is already installed." />

    <!-- Require Windows 10 1809 or later (the WireGuardNT driver and
         tokio::net::windows::named_pipe both rely on Win10 features). -->
    <Launch Condition="Installed OR (VersionNT &gt;= 603)"
            Message="SuperManager requires Windows 10 version 1809 or later." />

    <!-- File layout. WiX v4 introduces StandardDirectory which replaces
         the nested Directory hierarchy under TARGETDIR. -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLDIR" Name="SuperManager">
        <Directory Id="BinDir" Name="bin">
          <Component Id="DaemonExe" Bitness="always64">
            <File Id="supermgrd_win.exe"
                  Source="$(var.TargetDir)\supermgrd-win.exe"
                  KeyPath="yes" />
            <ServiceInstall Id="SuperManagerService"
                            Name="SuperManager"
                            DisplayName="SuperManager Daemon"
                            Description="Manages SSH keys, hosts, and VPN connections for SuperManager."
                            Type="ownProcess"
                            Start="auto"
                            ErrorControl="normal"
                            Account="LocalSystem"
                            Interactive="no"
                            Vital="yes">
              <ServiceDependency Id="Tcpip" />
              <ServiceDependency Id="Dhcp" />
            </ServiceInstall>
            <ServiceControl Id="SuperManagerSvcCtrl"
                            Name="SuperManager"
                            Start="install"
                            Stop="both"
                            Remove="uninstall"
                            Wait="yes" />
          </Component>

          <Component Id="GuiExe" Bitness="always64">
            <File Id="supermgr_win.exe"
                  Source="$(var.TargetDir)\supermgr-win.exe"
                  KeyPath="yes" />
          </Component>

          <Component Id="McpExe" Bitness="always64">
            <File Id="supermgr_mcp.exe"
                  Source="$(var.TargetDir)\supermgr-mcp.exe"
                  KeyPath="yes" />
          </Component>

          <!-- Single-file openfortivpn.exe drop (legacy path) is
               retained for users who hand-supply a static binary
               into vendor/openfortivpn.exe. -->
          <?if $(var.IncludeOpenfortivpn) = "yes" ?>
          <Component Id="OpenfortivpnExe" Bitness="always64">
            <File Id="openfortivpn.exe"
                  Source="vendor\openfortivpn.exe"
                  KeyPath="yes" />
          </Component>
          <?endif?>

          <!-- Full Cygwin-built openfortivpn bundle (openfortivpn.exe
               + pppd.exe + the cyg*.dll closure) lives in a dedicated
               subdirectory so cygwin1.dll never conflicts with a user's
               system Cygwin. The fragment + its directory entry are
               generated by scripts/windows/Stage-Openfortivpn.ps1
               from the Cygwin install + cygcheck DLL closure. -->
          <?if $(var.IncludeOpenfortivpnBundle) = "yes" ?>
          <Directory Id="BinOpenfortivpnDir" Name="openfortivpn-bundle" />
          <?endif?>
        </Directory>

        <Directory Id="ScriptsDir" Name="scripts">
          <Component Id="InstallSvcPs1" Bitness="always64">
            <File Id="install_service.ps1"
                  Source="scripts\windows\install-service.ps1"
                  KeyPath="yes" />
          </Component>
          <Component Id="UninstallSvcPs1" Bitness="always64">
            <File Id="uninstall_service.ps1"
                  Source="scripts\windows\uninstall-service.ps1"
                  KeyPath="yes" />
          </Component>
          <Component Id="SmokeTestPs1" Bitness="always64">
            <File Id="smoke_test.ps1"
                  Source="scripts\windows\smoke-test.ps1"
                  KeyPath="yes" />
          </Component>
        </Directory>

        <Directory Id="DocsDir" Name="docs">
          <Component Id="WindowsMd" Bitness="always64">
            <File Id="WINDOWS.md" Source="WINDOWS.md" KeyPath="yes" />
          </Component>
          <Component Id="ReadmeMd" Bitness="always64">
            <File Id="README.md" Source="README.md" KeyPath="yes" />
          </Component>
        </Directory>
      </Directory>
    </StandardDirectory>

    <!-- Start Menu shortcut for the GUI. -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="SuperManager">
        <Component Id="StartMenuShortcut" Bitness="always64">
          <Shortcut Id="SuperManagerShortcut"
                    Name="SuperManager"
                    Description="Manage SSH keys, hosts, and VPN connections"
                    Target="[BinDir]supermgr-win.exe"
                    WorkingDirectory="BinDir" />
          <RemoveFolder Id="ApplicationProgramsFolder" On="uninstall" />
          <RegistryValue Root="HKCU"
                         Key="Software\Sybr\SuperManager"
                         Name="StartMenuShortcut"
                         Type="integer"
                         Value="1"
                         KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <!-- Single feature so the user gets a "complete install" UI rather
         than an empty feature tree. -->
    <Feature Id="ProductFeature"
             Title="SuperManager"
             Level="1"
             Description="SuperManager daemon + GUI + MCP server"
             ConfigurableDirectory="INSTALLDIR">
      <ComponentRef Id="DaemonExe" />
      <ComponentRef Id="GuiExe" />
      <ComponentRef Id="McpExe" />
      <?if $(var.IncludeOpenfortivpn) = "yes" ?>
      <ComponentRef Id="OpenfortivpnExe" />
      <?endif?>
      <?if $(var.IncludeOpenfortivpnBundle) = "yes" ?>
      <ComponentGroupRef Id="OpenfortivpnBundleGroup" />
      <?endif?>
      <ComponentRef Id="InstallSvcPs1" />
      <ComponentRef Id="UninstallSvcPs1" />
      <ComponentRef Id="SmokeTestPs1" />
      <ComponentRef Id="WindowsMd" />
      <ComponentRef Id="ReadmeMd" />
      <ComponentRef Id="StartMenuShortcut" />
    </Feature>

    <!-- Pull in the auto-generated component list for the Cygwin
         openfortivpn bundle when the build script set the flag. -->
    <?if $(var.IncludeOpenfortivpnBundle) = "yes" ?>
    <?include openfortivpn-files.wxi ?>
    <?endif?>

    <!-- WixUI_InstallDir gives the user a browse-for-install-directory
         page. Standard for OSS apps without an EULA. -->
    <ui:WixUI Id="WixUI_InstallDir" />
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLDIR" />
  </Package>
</Wix>

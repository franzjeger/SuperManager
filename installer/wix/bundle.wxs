<?xml version="1.0" encoding="UTF-8"?>
<!--
  SuperManager-Setup.exe (WiX v4/v5 Burn bootstrapper).

  Unlike previous versions this bundle chains ONLY the SuperManager MSI.
  WireGuard and OpenVPN are no longer installed as separate applications —
  SuperManager.msi bundles only the minimal files each backend needs:
    bin\wireguard.dll    WireGuardNT (self-installs kernel driver on first use)
    bin\wintun.dll       Wintun (self-installs kernel driver on first use)
    bin\openvpn.exe      OpenVPN CLI only (no GUI, not installed system-wide)

  This means the end user gets ONE UAC prompt and NO extra applications
  appear in Add/Remove Programs.

  Build:
    .\installer\wix\build-msi.ps1 -Bundle
  (Ensure vendor\wireguard.dll, vendor\wintun.dll, vendor\openvpn.exe are
  present first — run scripts\windows\Get-VendorFiles.ps1.)
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:bal="http://wixtoolset.org/schemas/v4/wxs/bal">
  <Bundle Name="SuperManager"
          Version="!(bind.packageVersion.SuperManagerMsi)"
          Manufacturer="Sybr"
          UpgradeCode="2A9D5C71-8F4B-4E0A-B91C-7D2A3F5B1C04">

    <BootstrapperApplication>
      <bal:WixStandardBootstrapperApplication
          Theme="rtfLicense"
          LicenseFile="installer\wix\license.rtf"
          SuppressOptionsUI="yes" />
    </BootstrapperApplication>

    <Chain>
      <!-- SuperManager MSI — everything needed is bundled inside it. -->
      <MsiPackage Id="SuperManagerMsi"
                  SourceFile="installer\wix\SuperManager.msi"
                  Visible="yes" />
    </Chain>
  </Bundle>
</Wix>

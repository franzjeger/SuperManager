// SuperManager Windows UI — Slint declarative definition.
//
// Sidebar navigation switches the main pane between five views:
// Dashboard / SSH Keys / Hosts / VPN / Settings. Rust populates the
// in-properties, fires the callbacks, and consumes the in-out form
// state. The .slint side does no business logic and no transport.

import { Button, LineEdit, TextEdit, ListView, ComboBox, CheckBox, VerticalBox, HorizontalBox, ScrollView } from "std-widgets.slint";

// --------------------------------------------------------------------------
// Reusable card panel (replaces GroupBox — cleaner look)
// --------------------------------------------------------------------------
component Card inherits Rectangle {
    in property <string> title;
    background: white;
    border-radius: 8px;
    border-color: #cbd5e1;
    border-width: 1px;
    VerticalBox {
        padding: 16px;
        spacing: 0px;
        if root.title != "": Text {
            text: root.title;
            font-size: 13px;
            font-weight: 600;
            color: #1d2733;
        }
        if root.title != "": Rectangle { height: 12px; }
        @children
    }
}

// --------------------------------------------------------------------------
// Shared model structs (must match the JSON the daemon emits)
// --------------------------------------------------------------------------

export struct KeyRow {
    id: string,
    name: string,
    key_type: string,
    fingerprint: string,
    created_at: string,
}

export struct HostRow {
    id: string,
    label: string,
    hostname: string,
    username: string,
    device_type: string,
    customer: string,
    pinned: bool,
}

export struct ProfileRow {
    id: string,
    name: string,
    backend: string,
    host: string,
    username: string,
    full_tunnel: bool,
    auto_connect: bool,
}

// Full host detail surfaced on the Host detail view. Mirrors the
// JSON the daemon's `get_host` RPC emits, with Slint-friendly
// integer ports + bool flags.
export struct HostDetail {
    id: string,
    label: string,
    hostname: string,
    port: int,
    username: string,
    group: string,
    customer: string,
    device_type: string,
    auth_method: string,
    pinned: bool,
    created_at: string,
}

// --------------------------------------------------------------------------
// Sidebar item
// --------------------------------------------------------------------------

component SidebarItem inherits Rectangle {
    in property <string> label;
    in property <string> icon;
    in property <bool> selected;
    in property <int> badge;
    callback clicked();

    height: 44px;
    background: selected ? #2a3b52 : (touch.has-hover ? #1e2a3a : transparent);
    border-radius: 4px;
    animate background { duration: 80ms; }

    HorizontalBox {
        padding-left: 12px;
        padding-right: 12px;
        spacing: 10px;
        Text {
            text: icon;
            color: selected ? #6ec1ff : #93a4bb;
            font-size: 16px;
            vertical-alignment: center;
            width: 22px;
        }
        Text {
            text: label;
            color: selected ? white : #c4d2e3;
            font-weight: selected ? 600 : 400;
            vertical-alignment: center;
            horizontal-stretch: 1;
        }
        if badge > 0: Rectangle {
            background: #4d6079;
            border-radius: 9px;
            min-width: 26px;
            height: 18px;
            Text {
                text: badge;
                color: white;
                font-size: 11px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }

    touch := TouchArea { clicked => { root.clicked(); } }
}

// --------------------------------------------------------------------------
// Reusable status pill
// --------------------------------------------------------------------------

component StatusPill inherits Rectangle {
    in property <string> label;
    in property <color> fill;
    height: 22px;
    horizontal-stretch: 0;
    background: fill;
    border-radius: 11px;
    HorizontalBox {
        padding-left: 10px;
        padding-right: 10px;
        Text { text: label; color: white; font-size: 11px; vertical-alignment: center; }
    }
}

// --------------------------------------------------------------------------
// Top-level window
// --------------------------------------------------------------------------

export component AppWindow inherits Window {
    title: "SuperManager";
    preferred-width: 1080px;
    preferred-height: 720px;
    background: #f5f7fa;

    // ----- State pushed in from Rust -----
    in property <[KeyRow]>     keys: [];
    in property <[HostRow]>    hosts: [];
    in property <[ProfileRow]> profiles: [];

    in property <string>  daemon-status: "Connecting…";
    in property <bool>    daemon-connected: false;
    in property <string>  vpn-state: "Disconnected";
    in property <string>  vpn-profile-name: "";
    in property <string>  vpn-backend: "";
    in property <string>  last-error: "";
    in property <string>  last-status-message: "";
    in property <string>  last-refresh: "";
    in property <string>  app-version: "1.5.0";
    in property <string>  data-root: "C:\\ProgramData\\SuperManager";

    // ----- Navigation -----
    in-out property <int> current-view: 0;  // 0=Dashboard 1=SSH 2=Hosts 3=VPN 4=Settings 5=HostDetail

    // ----- Host detail state -----
    in property <HostDetail> selected-host;
    in-out property <string> host-cmd;
    in property <string> host-cmd-stdout;
    in property <string> host-cmd-stderr;
    in property <int>    host-cmd-exit-code: 0;
    in property <bool>   host-cmd-running: false;
    in property <string> host-test-result;
    in-out property <string> host-new-password;
    in-out property <string> host-new-api-token;
    in-out property <int>    host-new-api-port: 443;

    // Customer filter for the Hosts list.
    in-out property <string> hosts-customer-filter;

    // ----- Form bindings -----
    in-out property <string> new-key-name;
    in-out property <string> new-key-description;
    in-out property <int>    new-key-type-index: 0;

    in-out property <string> new-host-label;
    in-out property <string> new-host-hostname;
    in-out property <string> new-host-username: "root";
    in-out property <int>    new-host-port: 22;
    in-out property <string> new-host-group;
    in-out property <int>    new-host-device-type-index: 0;
    in-out property <int>    new-host-auth-method-index: 0;  // 0=password 1=key 2=api-token 3=none
    in-out property <string> host-search;

    in-out property <string> wg-import-name;
    in-out property <string> wg-import-text;
    in-out property <string> fc-import-name;
    in-out property <string> fc-import-host;
    in-out property <int>    fc-import-port: 443;
    in-out property <string> fc-import-username;
    in-out property <string> fc-import-password;
    in-out property <string> fg-import-name;
    in-out property <string> fg-import-host;
    in-out property <string> fg-import-username;
    in-out property <string> fg-import-password;
    in-out property <string> fg-import-psk;

    // ----- Callbacks -----
    callback refresh();
    callback generate-key(string /* name */, string /* description */, string /* key_type */);
    callback delete-key(string /* key_id */);
    callback export-key(string /* key_id */);

    callback add-host(string /* label */, string /* hostname */, int /* port */, string /* username */, string /* group */, string /* device_type */, string /* auth_method */);
    callback delete-host(string /* host_id */);
    callback toggle-host-pin(string /* host_id */);
    callback host-search-changed(string /* query */);
    callback open-host(string /* host_id */);
    callback close-host-detail();
    callback test-host-connection(string /* host_id */);
    callback ssh-execute(string /* host_id */, string /* command */);
    callback set-host-password(string /* host_id */, string /* password */);
    callback set-host-api-token(string /* host_id */, string /* token */, int /* port */);

    callback import-wireguard(string /* name */, string /* conf_text */);
    callback import-forticlient(string /* name */, string /* host */, int /* port */, string /* username */, string /* password */);
    callback import-fortigate(string /* name */, string /* host */, string /* username */, string /* password */, string /* psk */);
    callback delete-profile(string /* profile_id */);
    callback connect-profile(string /* profile_id */);
    callback disconnect-vpn();
    callback dismiss-error();

    // ======================================================================
    // Layout
    // ======================================================================

    HorizontalBox {
        spacing: 0;
        padding: 0;

        // ----- Sidebar -----
        Rectangle {
            background: #1d2733;
            width: 220px;
            VerticalBox {
                padding: 12px;
                spacing: 4px;

                // Brand
                Rectangle {
                    height: 56px;
                    HorizontalBox {
                        spacing: 10px;
                        padding-left: 4px;
                        Rectangle {
                            background: #6ec1ff;
                            border-radius: 8px;
                            width: 32px;
                            height: 32px;
                            Text { text: "S"; color: #1d2733; font-size: 18px; font-weight: 800; horizontal-alignment: center; vertical-alignment: center; }
                        }
                        VerticalBox {
                            spacing: 0;
                            padding: 0;
                            Text { text: "SuperManager"; color: white; font-size: 16px; font-weight: 700; }
                            Text { text: "v" + root.app-version; color: #7d8da4; font-size: 11px; }
                        }
                    }
                }

                Rectangle { height: 8px; }

                SidebarItem { label: "Dashboard"; icon: "▦"; selected: root.current-view == 0; clicked => { root.current-view = 0; } }
                SidebarItem { label: "SSH Keys";  icon: "🔑"; selected: root.current-view == 1; badge: root.keys.length;     clicked => { root.current-view = 1; } }
                SidebarItem { label: "Hosts";     icon: "▤"; selected: root.current-view == 2; badge: root.hosts.length;    clicked => { root.current-view = 2; } }
                SidebarItem { label: "VPN";       icon: "⇄"; selected: root.current-view == 3; badge: root.profiles.length; clicked => { root.current-view = 3; } }
                SidebarItem { label: "Settings";  icon: "⚙"; selected: root.current-view == 4; clicked => { root.current-view = 4; } }

                Rectangle { vertical-stretch: 1; }

                // Bottom status block
                Rectangle {
                    background: #16202b;
                    border-radius: 6px;
                    height: 76px;
                    VerticalBox {
                        padding: 10px;
                        spacing: 4px;
                        HorizontalBox {
                            spacing: 6px;
                            Rectangle {
                                background: root.daemon-connected ? #4ade80 : #ef4444;
                                border-radius: 4px;
                                width: 8px;
                                height: 8px;
                                y: 5px;
                            }
                            Text {
                                text: root.daemon-connected ? "Daemon online" : "Daemon offline";
                                color: white;
                                font-size: 11px;
                                vertical-alignment: center;
                            }
                        }
                        Text {
                            text: "VPN: " + root.vpn-state;
                            color: root.vpn-state == "Connected" ? #6ec1ff : #93a4bb;
                            font-size: 11px;
                        }
                        if root.vpn-profile-name != "": Text {
                            text: root.vpn-profile-name;
                            color: #c4d2e3;
                            font-size: 10px;
                            overflow: elide;
                        }
                    }
                }
            }
        }

        // ----- Main pane -----
        Rectangle {
            background: #f5f7fa;
            horizontal-stretch: 1;
            VerticalBox {
                padding: 24px;
                spacing: 16px;

                // Error banner
                if root.last-error != "": Rectangle {
                    background: #fee2e2;
                    border-color: #fca5a5;
                    border-width: 1px;
                    border-radius: 6px;
                    HorizontalBox {
                        padding: 12px;
                        Text {
                            text: "⚠ " + root.last-error;
                            color: #991b1b;
                            horizontal-stretch: 1;
                            wrap: word-wrap;
                        }
                        Button {
                            text: "✕";
                            clicked => { root.dismiss-error(); }
                        }
                    }
                }
                if root.last-status-message != "": Rectangle {
                    background: #dcfce7;
                    border-color: #86efac;
                    border-width: 1px;
                    border-radius: 6px;
                    HorizontalBox {
                        padding: 10px;
                        Text {
                            text: "✓ " + root.last-status-message;
                            color: #166534;
                            horizontal-stretch: 1;
                        }
                    }
                }

                // Switchable view
                if root.current-view == 0: dashboard-view := Rectangle {
                    VerticalBox {
                        padding: 0;
                        spacing: 16px;
                        Text { text: "Dashboard"; font-size: 22px; font-weight: 600; color: #1d2733; }

                        HorizontalBox {
                            spacing: 12px;

                            // VPN status card
                            Rectangle {
                                background: white;
                                border-radius: 8px;
                                border-color: #cbd5e1;
                                border-width: 1px;
                                horizontal-stretch: 2;
                                min-height: 140px;
                                VerticalBox {
                                    padding: 16px;
                                    spacing: 8px;
                                    HorizontalBox {
                                        Text { text: "VPN connection"; font-size: 13px; font-weight: 500; color: #374151; horizontal-stretch: 1; }
                                        StatusPill {
                                            label: root.vpn-state;
                                            fill: root.vpn-state == "Connected" ? #16a34a : (root.vpn-state == "Connecting" ? #d97706 : #4b5563);
                                        }
                                    }
                                    Text {
                                        text: root.vpn-profile-name != "" ? root.vpn-profile-name : "No active profile";
                                        font-size: 20px;
                                        font-weight: 600;
                                        color: #1d2733;
                                    }
                                    if root.vpn-backend != "": Text {
                                        text: "via " + root.vpn-backend;
                                        font-size: 13px;
                                        color: #374151;
                                    }
                                    Rectangle { vertical-stretch: 1; }
                                    HorizontalBox {
                                        if root.vpn-state == "Connected": Button {
                                            text: "Disconnect";
                                            clicked => { root.disconnect-vpn(); }
                                        }
                                        Button { text: "Manage profiles"; clicked => { root.current-view = 3; } }
                                    }
                                }
                            }

                            // Counts cards
                            VerticalBox {
                                horizontal-stretch: 1;
                                spacing: 12px;
                                Rectangle {
                                    background: white;
                                    border-radius: 8px;
                                    border-color: #cbd5e1;
                                    border-width: 1px;
                                    HorizontalBox {
                                        padding: 14px;
                                        Text { text: "SSH keys"; color: #374151; font-size: 13px; font-weight: 500; vertical-alignment: center; horizontal-stretch: 1; }
                                        Text { text: root.keys.length; font-size: 22px; font-weight: 700; color: #1d2733; }
                                    }
                                }
                                Rectangle {
                                    background: white;
                                    border-radius: 8px;
                                    border-color: #cbd5e1;
                                    border-width: 1px;
                                    HorizontalBox {
                                        padding: 14px;
                                        Text { text: "Managed hosts"; color: #374151; font-size: 13px; font-weight: 500; vertical-alignment: center; horizontal-stretch: 1; }
                                        Text { text: root.hosts.length; font-size: 22px; font-weight: 700; color: #1d2733; }
                                    }
                                }
                                Rectangle {
                                    background: white;
                                    border-radius: 8px;
                                    border-color: #cbd5e1;
                                    border-width: 1px;
                                    HorizontalBox {
                                        padding: 14px;
                                        Text { text: "VPN profiles"; color: #374151; font-size: 13px; font-weight: 500; vertical-alignment: center; horizontal-stretch: 1; }
                                        Text { text: root.profiles.length; font-size: 22px; font-weight: 700; color: #1d2733; }
                                    }
                                }
                            }
                        }

                        Rectangle {
                            background: white;
                            border-radius: 8px;
                            border-color: #cbd5e1;
                            border-width: 1px;
                            VerticalBox {
                                padding: 16px;
                                spacing: 6px;
                                Text { text: "Activity"; font-size: 13px; font-weight: 500; color: #374151; }
                                Text {
                                    text: root.last-refresh != "" ? ("Last refresh: " + root.last-refresh) : "Refresh has not run yet";
                                    color: #1d2733;
                                }
                                Text {
                                    text: "Daemon status: " + root.daemon-status;
                                    color: #1d2733;
                                }
                            }
                        }

                        Rectangle { vertical-stretch: 1; }
                        HorizontalBox {
                            Rectangle { horizontal-stretch: 1; }
                            Button { text: "Refresh"; clicked => { root.refresh(); } }
                        }
                    }
                }

                if root.current-view == 1: ssh-view := Rectangle {
                    VerticalBox {
                        padding: 0;
                        spacing: 16px;
                        Text { text: "SSH Keys"; font-size: 22px; font-weight: 600; color: #1d2733; }

                        Card {
                            title: "Generate new key";
                            VerticalBox {
                                spacing: 10px;
                                padding: 0;
                                HorizontalBox {
                                    Text { text: "Name"; vertical-alignment: center; min-width: 120px; color: #1d2733; }
                                    LineEdit { placeholder-text: "frank@workstation"; text <=> root.new-key-name; }
                                }
                                HorizontalBox {
                                    Text { text: "Description"; vertical-alignment: center; min-width: 120px; color: #1d2733; }
                                    LineEdit { placeholder-text: "primary workstation key"; text <=> root.new-key-description; }
                                }
                                HorizontalBox {
                                    Text { text: "Type"; vertical-alignment: center; min-width: 120px; color: #1d2733; }
                                    ComboBox {
                                        model: ["ed25519", "rsa4096", "rsa2048"];
                                        current-index <=> root.new-key-type-index;
                                    }
                                    Rectangle { horizontal-stretch: 1; }
                                    Button {
                                        text: "Generate";
                                        primary: true;
                                        clicked => {
                                            root.generate-key(
                                                root.new-key-name,
                                                root.new-key-description,
                                                root.new-key-type-index == 0 ? "ed25519"
                                                    : root.new-key-type-index == 1 ? "rsa4096"
                                                    : "rsa2048"
                                            );
                                        }
                                    }
                                }
                            }
                        }

                        Card {
                            title: "Managed keys (" + root.keys.length + ")";
                            ScrollView {
                                min-height: 240px;
                                VerticalBox {
                                    spacing: 0;
                                    padding: 0;
                                    for key[i] in root.keys: Rectangle {
                                        height: 64px;
                                        background: mod(i, 2) == 0 ? #fafafa : white;
                                        border-radius: 4px;
                                        HorizontalBox {
                                            padding-left: 12px;
                                            padding-right: 12px;
                                            spacing: 12px;
                                            VerticalBox {
                                                horizontal-stretch: 1;
                                                spacing: 2px;
                                                padding: 0;
                                                Text { text: key.name; font-weight: 600; color: #1d2733; }
                                                Text {
                                                    text: key.key_type + "  ·  " + key.fingerprint;
                                                    color: #374151;
                                                    font-size: 13px;
                                                    overflow: elide;
                                                }
                                            }
                                            Button { text: "Copy"; clicked => { root.export-key(key.id); } }
                                            Button { text: "Delete"; clicked => { root.delete-key(key.id); } }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }

                if root.current-view == 2: hosts-view := Rectangle {
                    VerticalBox {
                        padding: 0;
                        spacing: 16px;
                        Text { text: "Hosts"; font-size: 22px; font-weight: 600; color: #1d2733; }

                        Card {
                            title: "Add host";
                            VerticalBox {
                                spacing: 10px;
                                padding: 0;
                                HorizontalBox {
                                    Text { text: "Label"; vertical-alignment: center; min-width: 100px; color: #1d2733; }
                                    LineEdit { placeholder-text: "prod-web-01"; text <=> root.new-host-label; }
                                    Text { text: "Hostname"; vertical-alignment: center; min-width: 90px; color: #1d2733; }
                                    LineEdit { placeholder-text: "10.0.1.42"; text <=> root.new-host-hostname; }
                                }
                                HorizontalBox {
                                    Text { text: "Username"; vertical-alignment: center; min-width: 100px; color: #1d2733; }
                                    LineEdit { text <=> root.new-host-username; }
                                    Text { text: "Port"; vertical-alignment: center; min-width: 50px; color: #1d2733; }
                                    LineEdit {
                                        text: root.new-host-port;
                                        edited(s) => { root.new-host-port = s.to-float(); }
                                    }
                                    Text { text: "Group"; vertical-alignment: center; min-width: 60px; color: #1d2733; }
                                    LineEdit { placeholder-text: "prod"; text <=> root.new-host-group; }
                                }
                                HorizontalBox {
                                    Text { text: "Device type"; vertical-alignment: center; min-width: 100px; color: #1d2733; }
                                    ComboBox {
                                        model: ["linux", "fortigate", "unifi", "opnsense", "sophos", "openwrt", "pfsense"];
                                        current-index <=> root.new-host-device-type-index;
                                    }
                                    Text { text: "Auth"; vertical-alignment: center; min-width: 50px; color: #1d2733; }
                                    ComboBox {
                                        model: ["password", "key", "api-token", "none"];
                                        current-index <=> root.new-host-auth-method-index;
                                    }
                                    Rectangle { horizontal-stretch: 1; }
                                    Button {
                                        text: "Add";
                                        primary: true;
                                        clicked => {
                                            root.add-host(
                                                root.new-host-label,
                                                root.new-host-hostname,
                                                root.new-host-port,
                                                root.new-host-username,
                                                root.new-host-group,
                                                root.new-host-device-type-index == 0 ? "linux"
                                                    : root.new-host-device-type-index == 1 ? "fortigate"
                                                    : root.new-host-device-type-index == 2 ? "unifi"
                                                    : root.new-host-device-type-index == 3 ? "opnsense"
                                                    : root.new-host-device-type-index == 4 ? "sophos"
                                                    : root.new-host-device-type-index == 5 ? "openwrt"
                                                    : "pfsense",
                                                root.new-host-auth-method-index == 0 ? "password"
                                                    : root.new-host-auth-method-index == 1 ? "key"
                                                    : root.new-host-auth-method-index == 2 ? "api-token"
                                                    : "none"
                                            );
                                        }
                                    }
                                }
                            }
                        }

                        Card {
                            title: "Managed hosts (" + root.hosts.length + ")";
                            VerticalBox {
                                spacing: 10px;
                                padding: 0;
                                HorizontalBox {
                                    Text { text: "🔍"; vertical-alignment: center; }
                                    LineEdit {
                                        placeholder-text: "search by label or hostname";
                                        text <=> root.host-search;
                                        edited(s) => { root.host-search-changed(s); }
                                    }
                                }
                                ScrollView {
                                    min-height: 280px;
                                    VerticalBox {
                                        spacing: 0;
                                        padding: 0;
                                        // Filter happens server-side: Rust rebuilds the
                                        // `hosts` model when `host-search` changes. We
                                        // render whatever the model contains here.
                                        for host[i] in root.hosts: host-row := Rectangle {
                                            height: 60px;
                                            background: host-row-touch.has-hover ? #eff6ff
                                                : (mod(i, 2) == 0 ? #fafafa : white);
                                            border-radius: 4px;
                                            animate background { duration: 60ms; }
                                            host-row-touch := TouchArea {
                                                clicked => { root.open-host(host.id); }
                                            }
                                            HorizontalBox {
                                                padding-left: 12px;
                                                padding-right: 12px;
                                                spacing: 12px;
                                                VerticalBox {
                                                    horizontal-stretch: 1;
                                                    spacing: 2px;
                                                    padding: 0;
                                                    Text {
                                                        text: (host.pinned ? "★ " : "") + host.label;
                                                        font-weight: 600;
                                                        color: #1d2733;
                                                    }
                                                    Text {
                                                        text: host.username + "@" + host.hostname + "  ·  " + host.device_type;
                                                        color: #374151;
                                                        font-size: 13px;
                                                        overflow: elide;
                                                    }
                                                }
                                                if host.customer != "": StatusPill {
                                                    label: host.customer;
                                                    fill: #475569;
                                                }
                                                Button {
                                                    text: host.pinned ? "Unpin" : "Pin";
                                                    clicked => { root.toggle-host-pin(host.id); }
                                                }
                                                Button {
                                                    text: "Open";
                                                    clicked => { root.open-host(host.id); }
                                                }
                                                Button {
                                                    text: "Delete";
                                                    clicked => { root.delete-host(host.id); }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }

                if root.current-view == 3: vpn-view := Rectangle {
                    VerticalBox {
                        padding: 0;
                        spacing: 16px;
                        Text { text: "VPN profiles"; font-size: 22px; font-weight: 600; color: #1d2733; }

                        Rectangle {
                            background: white;
                            border-radius: 8px;
                            border-color: #cbd5e1;
                            border-width: 1px;
                            HorizontalBox {
                                padding: 16px;
                                StatusPill {
                                    label: root.vpn-state;
                                    fill: root.vpn-state == "Connected" ? #16a34a : (root.vpn-state == "Connecting" ? #d97706 : #4b5563);
                                }
                                Text {
                                    text: root.vpn-profile-name != "" ? root.vpn-profile-name : "No active profile";
                                    color: #1d2733;
                                    font-weight: 600;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                }
                                if root.vpn-state == "Connected": Button {
                                    text: "Disconnect";
                                    clicked => { root.disconnect-vpn(); }
                                }
                            }
                        }

                        Card {
                            title: "Import FortiGate IKEv2 (Windows RAS)";
                            VerticalBox {
                                spacing: 10px;
                                padding: 0;
                                HorizontalBox {
                                    Text { text: "Name"; vertical-alignment: center; min-width: 80px; color: #1d2733; }
                                    LineEdit { placeholder-text: "client-fortigate-ikev2"; text <=> root.fg-import-name; }
                                    Text { text: "Host"; vertical-alignment: center; min-width: 50px; color: #1d2733; }
                                    LineEdit { placeholder-text: "vpn.example.com"; text <=> root.fg-import-host; }
                                }
                                HorizontalBox {
                                    Text { text: "Username"; vertical-alignment: center; min-width: 80px; color: #1d2733; }
                                    LineEdit { text <=> root.fg-import-username; }
                                    Text { text: "Password"; vertical-alignment: center; min-width: 70px; color: #1d2733; }
                                    LineEdit {
                                        text <=> root.fg-import-password;
                                        input-type: password;
                                    }
                                }
                                HorizontalBox {
                                    Text { text: "Group PSK"; vertical-alignment: center; min-width: 80px; color: #1d2733; }
                                    LineEdit {
                                        text <=> root.fg-import-psk;
                                        input-type: password;
                                        placeholder-text: "IKE shared secret";
                                    }
                                    Rectangle { horizontal-stretch: 1; }
                                    Button {
                                        text: "Import";
                                        primary: true;
                                        clicked => {
                                            root.import-fortigate(
                                                root.fg-import-name,
                                                root.fg-import-host,
                                                root.fg-import-username,
                                                root.fg-import-password,
                                                root.fg-import-psk
                                            );
                                        }
                                    }
                                }
                            }
                        }

                        HorizontalBox {
                            spacing: 16px;
                            Card {
                                title: "Import WireGuard (.conf)";
                                horizontal-stretch: 1;
                                VerticalBox {
                                    spacing: 10px;
                                    padding: 0;
                                    HorizontalBox {
                                        Text { text: "Name"; vertical-alignment: center; min-width: 80px; color: #1d2733; }
                                        LineEdit { placeholder-text: "office-vpn"; text <=> root.wg-import-name; }
                                    }
                                    Text { text: ".conf contents"; color: #1d2733; font-size: 13px; }
                                    TextEdit {
                                        min-height: 140px;
                                        text <=> root.wg-import-text;
                                        placeholder-text: "[Interface]\nPrivateKey = ...\nAddress = 10.0.0.2/24\n\n[Peer]\n...";
                                    }
                                    HorizontalBox {
                                        Rectangle { horizontal-stretch: 1; }
                                        Button {
                                            text: "Import";
                                            primary: true;
                                            clicked => { root.import-wireguard(root.wg-import-name, root.wg-import-text); }
                                        }
                                    }
                                }
                            }

                            Card {
                                title: "Import FortiGate SSL VPN";
                                horizontal-stretch: 1;
                                VerticalBox {
                                    spacing: 10px;
                                    padding: 0;
                                    HorizontalBox {
                                        Text { text: "Name"; vertical-alignment: center; min-width: 80px; color: #1d2733; }
                                        LineEdit { placeholder-text: "client-fortigate"; text <=> root.fc-import-name; }
                                    }
                                    HorizontalBox {
                                        Text { text: "Host"; vertical-alignment: center; min-width: 80px; color: #1d2733; }
                                        LineEdit { placeholder-text: "vpn.example.com"; text <=> root.fc-import-host; }
                                        Text { text: "Port"; vertical-alignment: center; min-width: 50px; color: #1d2733; }
                                        LineEdit {
                                            text: root.fc-import-port;
                                            edited(s) => { root.fc-import-port = s.to-float(); }
                                        }
                                    }
                                    HorizontalBox {
                                        Text { text: "Username"; vertical-alignment: center; min-width: 80px; color: #1d2733; }
                                        LineEdit { text <=> root.fc-import-username; }
                                    }
                                    HorizontalBox {
                                        Text { text: "Password"; vertical-alignment: center; min-width: 80px; color: #1d2733; }
                                        LineEdit {
                                            text <=> root.fc-import-password;
                                            input-type: password;
                                        }
                                    }
                                    HorizontalBox {
                                        Rectangle { horizontal-stretch: 1; }
                                        Button {
                                            text: "Import";
                                            primary: true;
                                            clicked => {
                                                root.import-forticlient(
                                                    root.fc-import-name,
                                                    root.fc-import-host,
                                                    root.fc-import-port,
                                                    root.fc-import-username,
                                                    root.fc-import-password
                                                );
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        Card {
                            title: "Profiles (" + root.profiles.length + ")";
                            ScrollView {
                                min-height: 240px;
                                VerticalBox {
                                    spacing: 0;
                                    padding: 0;
                                    for prof[i] in root.profiles: Rectangle {
                                        height: 64px;
                                        background: mod(i, 2) == 0 ? #fafafa : white;
                                        border-radius: 4px;
                                        HorizontalBox {
                                            padding-left: 12px;
                                            padding-right: 12px;
                                            spacing: 12px;
                                            VerticalBox {
                                                horizontal-stretch: 1;
                                                spacing: 2px;
                                                padding: 0;
                                                Text { text: prof.name; font-weight: 600; color: #1d2733; }
                                                Text {
                                                    text: prof.backend + (prof.host != "" ? "  ·  " + prof.host : "");
                                                    color: #374151;
                                                    font-size: 13px;
                                                    overflow: elide;
                                                }
                                            }
                                            Button {
                                                text: "Connect";
                                                enabled: root.vpn-state != "Connected" || root.vpn-profile-name != prof.name;
                                                clicked => { root.connect-profile(prof.id); }
                                            }
                                            Button {
                                                text: "Delete";
                                                clicked => { root.delete-profile(prof.id); }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }

                if root.current-view == 4: settings-view := Rectangle {
                    VerticalBox {
                        padding: 0;
                        spacing: 16px;
                        Text { text: "Settings"; font-size: 22px; font-weight: 600; color: #1d2733; }

                        Rectangle {
                            background: white;
                            border-radius: 8px;
                            border-color: #cbd5e1;
                            border-width: 1px;
                            VerticalBox {
                                padding: 16px;
                                spacing: 8px;
                                Text { text: "Daemon"; font-size: 14px; font-weight: 600; color: #1d2733; }
                                HorizontalBox {
                                    Text { text: "Service status:"; color: #374151; min-width: 140px; vertical-alignment: center; }
                                    StatusPill {
                                        label: root.daemon-connected ? "Online" : "Offline";
                                        fill: root.daemon-connected ? #16a34a : #ef4444;
                                    }
                                    Rectangle { horizontal-stretch: 1; }
                                }
                                HorizontalBox {
                                    Text { text: "Pipe address:"; color: #374151; min-width: 140px; }
                                    Text { text: "\\\\.\\pipe\\supermgrd"; color: #1d2733; font-size: 13px; }
                                }
                                HorizontalBox {
                                    Text { text: "Data directory:"; color: #374151; min-width: 140px; }
                                    Text { text: root.data-root; color: #1d2733; font-size: 13px; overflow: elide; }
                                }
                            }
                        }

                        Rectangle {
                            background: white;
                            border-radius: 8px;
                            border-color: #cbd5e1;
                            border-width: 1px;
                            VerticalBox {
                                padding: 16px;
                                spacing: 8px;
                                Text { text: "About"; font-size: 14px; font-weight: 600; color: #1d2733; }
                                HorizontalBox {
                                    Text { text: "Version:"; color: #374151; min-width: 140px; }
                                    Text { text: root.app-version; color: #1d2733; }
                                }
                                HorizontalBox {
                                    Text { text: "Repository:"; color: #374151; min-width: 140px; }
                                    Text { text: "github.com/franzjeger/SuperManager"; color: #1d2733; }
                                }
                                HorizontalBox {
                                    Text { text: "License:"; color: #374151; min-width: 140px; }
                                    Text { text: "GPL-3.0-or-later"; color: #1d2733; }
                                }
                            }
                        }

                        Rectangle { vertical-stretch: 1; }
                    }
                }

                if root.current-view == 5: host-detail-view := Rectangle {
                    VerticalBox {
                        padding: 0;
                        spacing: 16px;

                        HorizontalBox {
                            Button {
                                text: "← Back to hosts";
                                clicked => { root.close-host-detail(); }
                            }
                            Text {
                                text: root.selected-host.label != "" ? root.selected-host.label : "(host)";
                                font-size: 22px;
                                font-weight: 600;
                                color: #1d2733;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                            }
                            if root.selected-host.pinned: StatusPill { label: "Pinned"; fill: #f59e0b; }
                            StatusPill {
                                label: root.selected-host.device_type;
                                fill: #475569;
                            }
                        }

                        // Metadata card
                        Rectangle {
                            background: white;
                            border-radius: 8px;
                            border-color: #cbd5e1;
                            border-width: 1px;
                            VerticalBox {
                                padding: 16px;
                                spacing: 6px;
                                Text { text: "Connection details"; font-size: 13px; font-weight: 500; color: #374151; }
                                HorizontalBox {
                                    Text { text: "SSH target:"; color: #374151; min-width: 130px; }
                                    Text {
                                        text: root.selected-host.username + "@" + root.selected-host.hostname + ":" + root.selected-host.port;
                                        color: #1d2733;
                                        font-size: 13px;
                                    }
                                }
                                HorizontalBox {
                                    Text { text: "Auth method:"; color: #374151; min-width: 130px; }
                                    Text { text: root.selected-host.auth_method; color: #1d2733; font-size: 13px; }
                                }
                                if root.selected-host.group != "": HorizontalBox {
                                    Text { text: "Group:"; color: #374151; min-width: 130px; }
                                    Text { text: root.selected-host.group; color: #1d2733; font-size: 13px; }
                                }
                                if root.selected-host.customer != "": HorizontalBox {
                                    Text { text: "Customer:"; color: #374151; min-width: 130px; }
                                    Text { text: root.selected-host.customer; color: #1d2733; font-size: 13px; }
                                }
                                if root.selected-host.created_at != "": HorizontalBox {
                                    Text { text: "Added:"; color: #374151; min-width: 130px; }
                                    Text { text: root.selected-host.created_at; color: #1d2733; font-size: 13px; }
                                }
                            }
                        }

                        // Test connection
                        Rectangle {
                            background: white;
                            border-radius: 8px;
                            border-color: #cbd5e1;
                            border-width: 1px;
                            VerticalBox {
                                padding: 16px;
                                spacing: 8px;
                                HorizontalBox {
                                    Text { text: "Connectivity"; font-size: 14px; font-weight: 600; color: #1d2733; horizontal-stretch: 1; }
                                    Button {
                                        text: "Test connection";
                                        clicked => { root.test-host-connection(root.selected-host.id); }
                                    }
                                }
                                if root.host-test-result != "": Text {
                                    text: root.host-test-result;
                                    color: #374151;
                                    font-size: 13px;
                                    wrap: word-wrap;
                                }
                            }
                        }

                        // SSH execute
                        Rectangle {
                            background: white;
                            border-radius: 8px;
                            border-color: #cbd5e1;
                            border-width: 1px;
                            VerticalBox {
                                padding: 16px;
                                spacing: 8px;
                                Text { text: "Run command via SSH"; font-size: 14px; font-weight: 600; color: #1d2733; }
                                HorizontalBox {
                                    LineEdit {
                                        placeholder-text: "uname -a";
                                        text <=> root.host-cmd;
                                        enabled: !root.host-cmd-running;
                                    }
                                    Button {
                                        text: root.host-cmd-running ? "Running…" : "Run";
                                        primary: true;
                                        enabled: !root.host-cmd-running && root.host-cmd != "";
                                        clicked => { root.ssh-execute(root.selected-host.id, root.host-cmd); }
                                    }
                                }
                                if root.host-cmd-stdout != "" || root.host-cmd-stderr != "" || root.host-cmd-running: VerticalBox {
                                    spacing: 4px;
                                    padding: 0;
                                    Text {
                                        text: "Exit code: " + root.host-cmd-exit-code;
                                        color: root.host-cmd-exit-code == 0 ? #166534 : #b91c1c;
                                        font-size: 13px;
                                        font-weight: 500;
                                    }
                                    if root.host-cmd-stdout != "": Rectangle {
                                        background: #0f172a;
                                        border-radius: 4px;
                                        VerticalBox {
                                            padding: 8px;
                                            Text {
                                                text: "stdout";
                                                color: #94a3b8;
                                                font-size: 11px;
                                            }
                                            Text {
                                                text: root.host-cmd-stdout;
                                                color: #e2e8f0;
                                                font-size: 13px;
                                                font-family: "Consolas, monospace";
                                                wrap: word-wrap;
                                            }
                                        }
                                    }
                                    if root.host-cmd-stderr != "": Rectangle {
                                        background: #450a0a;
                                        border-radius: 4px;
                                        VerticalBox {
                                            padding: 8px;
                                            Text {
                                                text: "stderr";
                                                color: #fca5a5;
                                                font-size: 11px;
                                            }
                                            Text {
                                                text: root.host-cmd-stderr;
                                                color: #fecaca;
                                                font-size: 13px;
                                                font-family: "Consolas, monospace";
                                                wrap: word-wrap;
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        // Credentials
                        Rectangle {
                            background: white;
                            border-radius: 8px;
                            border-color: #cbd5e1;
                            border-width: 1px;
                            VerticalBox {
                                padding: 16px;
                                spacing: 8px;
                                Text { text: "Credentials"; font-size: 14px; font-weight: 600; color: #1d2733; }
                                HorizontalBox {
                                    Text { text: "Set password:"; color: #374151; min-width: 130px; vertical-alignment: center; }
                                    LineEdit {
                                        input-type: password;
                                        text <=> root.host-new-password;
                                        placeholder-text: "•••••••";
                                    }
                                    Button {
                                        text: "Save";
                                        enabled: root.host-new-password != "";
                                        clicked => {
                                            root.set-host-password(root.selected-host.id, root.host-new-password);
                                            root.host-new-password = "";
                                        }
                                    }
                                }
                                HorizontalBox {
                                    Text { text: "Set API token:"; color: #374151; min-width: 130px; vertical-alignment: center; }
                                    LineEdit {
                                        input-type: password;
                                        text <=> root.host-new-api-token;
                                        placeholder-text: "bearer token";
                                    }
                                    Text { text: "Port"; vertical-alignment: center; color: #374151; }
                                    LineEdit {
                                        text: root.host-new-api-port;
                                        edited(s) => { root.host-new-api-port = s.to-float(); }
                                    }
                                    Button {
                                        text: "Save";
                                        enabled: root.host-new-api-token != "";
                                        clicked => {
                                            root.set-host-api-token(
                                                root.selected-host.id,
                                                root.host-new-api-token,
                                                root.host-new-api-port
                                            );
                                            root.host-new-api-token = "";
                                        }
                                    }
                                }
                            }
                        }

                        Rectangle { vertical-stretch: 1; }
                    }
                }
            }
        }
    }
}
